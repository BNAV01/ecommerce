{
  "realm": "ecommerce",
  "enabled": true,
  "displayName": "Ecommerce Realm",
  "roles": {
    "realm": [
      {
        "name": "ROLE_ADMIN"
      },
      {
        "name": "ROLE_CUSTOMER"
      }
    ]
  },
  "clients": [
    {
      "clientId": "shop-web",
      "name": "Shop Angular App",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "admin-web",
      "name": "Admin Angular App",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:4201/*"
      ],
      "webOrigins": [
        "http://localhost:4201"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "gateway",
      "name": "Gateway",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "secret": "gateway-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Platform",
      "lastName": "Admin",
      "email": "admin@ecommerce.local",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ROLE_ADMIN"
      ]
    },
    {
      "username": "customer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Customer",
      "email": "customer@ecommerce.local",
      "credentials": [
        {
          "type": "password",
          "value": "customer123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ROLE_CUSTOMER"
      ]
    }
  ]
}
