{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "",
  "projects": {
    "shop": {
      "projectType": "application",
      "root": "shop",
      "sourceRoot": "shop/src",
      "prefix": "shop",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/shop",
            "index": "shop/src/index.html",
            "browser": "shop/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "shop/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "shop/public"
              }
            ],
            "styles": ["shop/src/styles.scss"],
            "inlineStyleLanguage": "scss"
          },
          "configurations": {
            "production": {
              "optimization": true,
              "extractLicenses": true,
              "sourceMap": false,
              "fileReplacements": [
                {
                  "replace": "shop/src/environments/environment.ts",
                  "with": "shop/src/environments/environment.production.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "shop/src/environments/environment.ts",
                  "with": "shop/src/environments/environment.development.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "development": {
              "buildTarget": "shop:build:development",
              "port": 4200
            },
            "production": {
              "buildTarget": "shop:build:production",
              "port": 4200
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "shop/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "shop/public"
              }
            ],
            "styles": ["shop/src/styles.scss"]
          }
        }
      }
    },
    "admin": {
      "projectType": "application",
      "root": "admin",
      "sourceRoot": "admin/src",
      "prefix": "admin",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/admin",
            "index": "admin/src/index.html",
            "browser": "admin/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "admin/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "admin/public"
              }
            ],
            "styles": ["admin/src/styles.scss"],
            "inlineStyleLanguage": "scss"
          },
          "configurations": {
            "production": {
              "optimization": true,
              "extractLicenses": true,
              "sourceMap": false,
              "fileReplacements": [
                {
                  "replace": "admin/src/environments/environment.ts",
                  "with": "admin/src/environments/environment.production.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "admin/src/environments/environment.ts",
                  "with": "admin/src/environments/environment.development.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "development": {
              "buildTarget": "admin:build:development",
              "port": 4201
            },
            "production": {
              "buildTarget": "admin:build:production",
              "port": 4201
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "admin/tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "admin/public"
              }
            ],
            "styles": ["admin/src/styles.scss"]
          }
        }
      }
    }
  }
}

